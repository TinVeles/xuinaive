# Pinned upstream artifacts for vendored components/x-ui-pro/x-ui-pro.sh.
# Used by verify-upstream-binaries.sh to enforce SHA256 integrity before
# x-ui-pro.sh executes wget/install commands.
#
# Modes:
#   1. STRICT: Copy this file to upstream-pins.env and fill in real SHA256
#      values + exact versions. Wrapper enforces match; mismatch -> die.
#   2. TOFU (Trust On First Use): Leave upstream-pins.env absent. Wrapper
#      downloads, computes hashes, writes upstream-pins.lock with the values.
#      Subsequent runs verify against the lock. First install is trusted.
#
# To compute current hashes manually:
#   bash verify-upstream-binaries.sh --print-current

X_UI_VERSION=""               # e.g. v2.5.6
X_UI_TAR_SHA256_AMD64=""      # x-ui-linux-amd64.tar.gz
X_UI_TAR_SHA256_ARM64=""      # x-ui-linux-arm64.tar.gz
X_UI_SH_SHA256=""             # https://raw.githubusercontent.com/MHSanaei/3x-ui/main/x-ui.sh
X_UI_RC_SHA256=""             # https://raw.githubusercontent.com/MHSanaei/3x-ui/main/x-ui.rc (Alpine init)

SUB2SINGBOX_VERSION="v0.0.9"
SUB2SINGBOX_TAR_SHA256_AMD64=""  # sub2sing-box_<ver>_linux_amd64.tar.gz
SUB2SINGBOX_TAR_SHA256_ARM64=""  # sub2sing-box_<ver>_linux_arm64.tar.gz
