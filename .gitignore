# Runtime configuration and generated access data
config.env
*.local.env
.env
.env.*
!.env.example
!config.example.env
access-info.txt

# Logs, temporary files, and local command output
*.log
*.out
*.err
*.tmp
*.temp
tmp/
temp/
.cache/

# Secrets, certificates, and keys
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks
*.keystore
id_rsa*
id_ed25519*
*.ovpn
*.wg
wg*.conf

# Databases and panel/runtime state
*.db
*.sqlite
*.sqlite3
*.session
*.pid
*.lock
data/

# Backups and archives that may contain secrets
*.bak
*.bak.*
*.backup
*.backup.*
backups/
backup/
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

# Node/runtime dependencies generated by vendored panels
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.backup*
