# Copy to config.env for local planning.
# This first safe version does not run real installers and does not write system configs.

# x-ui-pro / 3x-ui domain for panel, subscriptions, websocket/grpc/httpupgrade front.
XUI_DOMAIN="x.example.com"

# NaiveProxy/Caddy domain. Use a different domain or subdomain from XUI_DOMAIN.
NAIVE_DOMAIN="n.example.com"

# REALITY destination/serverName domain used by the x-ui-pro upstream script.
REALITY_DEST="r.example.com"

# Email planned for Caddy/Let's Encrypt in a future real NaiveProxy installer.
NAIVE_EMAIL="admin@example.com"

# RIXXX Panel NaiveProxy + Mieru mode.
# Used by: ./install.sh --mode all --install --yes
RIXXX_DOMAIN="vpn.example.com"
RIXXX_EMAIL="admin@example.com"
RIXXX_BACKEND_LISTEN="127.0.0.1:9445"
RIXXX_ACCESS="ssh-tunnel" # safe default: panel bound to 127.0.0.1:3000, access via ssh -L 3000:127.0.0.1:3000.
RIXXX_MASQUERADE_URL=""
RIXXX_MIERU_START="2012"
RIXXX_MIERU_END="2022"

# Legacy aliases still accepted by scripts for older config.env files.
NH_PROXY_DOMAIN="$RIXXX_DOMAIN"
NH_PROXY_EMAIL="$RIXXX_EMAIL"
NH_BACKEND_LISTEN="$RIXXX_BACKEND_LISTEN"
NH_ACCESS="$RIXXX_ACCESS"

# Cloudflare WARP local proxy. Disabled by default; enable install with --install-warp.
WARP_PROXY_HOST="127.0.0.1"
WARP_PROXY_PORT="40000"
WARP_OUTBOUND_TAG="warp-cli"
WARP_AI_DOMAINS="domain:openai.com,domain:chatgpt.com,domain:oaistatic.com,domain:oaiusercontent.com,domain:anthropic.com,domain:claude.ai,domain:gemini.google.com,domain:aistudio.google.com,domain:ai.google.dev,domain:generativelanguage.googleapis.com,domain:aiplatform.googleapis.com,domain:googleapis.com,domain:gstatic.com,domain:googleusercontent.com,domain:ggpht.com,domain:clients6.google.com,domain:accounts.google.com,domain:apis.google.com,domain:ogs.google.com,domain:www.google.com,domain:play.google.com,domain:withgoogle.com,domain:youtube.com,domain:ytimg.com,domain:notebooklm.google.com,domain:notebooklm.google"
WARP_INBOUND_TAG="all"
WARP_ROUTE_PORT="443"
XUI_ENABLE_WARP_ROUTING="0"
XUI_APPLY_WARP_TEMPLATE="0" # default safe mode: write snippet only, do not edit x-ui routing settings
XUI_CREATE_DIRECT="1"     # standard preset inbound clients; default enabled
XUI_PANEL_LINE="latest"   # latest upstream 3x-ui v3 with SQLite; use legacy for fixed 2.9.4
XUI_PRESET_PROFILE="stable" # stable core by default; use extended for extra experimental presets

# Bulk profile generator. Full all-in-one installs enable it by default.
GENERATE_PROFILES="1"
PROFILE_COUNT="15"
PROFILE_PREFIX="auto"
