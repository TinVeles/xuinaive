# Copy to config.env for local planning.
# This first safe version does not run real installers and does not write system configs.

# x-ui-pro / 3x-ui domain for panel, subscriptions, websocket/grpc/httpupgrade front.
XUI_DOMAIN="x.example.com"

# NaiveProxy/Caddy domain. Use a different domain or subdomain from XUI_DOMAIN.
NAIVE_DOMAIN="n.example.com"

# REALITY destination/serverName domain used by the x-ui-pro upstream script.
REALITY_DEST="r.example.com"

# Email planned for Caddy/Let's Encrypt in a future real NaiveProxy installer.
NAIVE_EMAIL="admin@example.com"

# N+H Panel Naive + Hysteria2 mode.
# Used by: ./install.sh --mode all --install --yes
NH_PROXY_DOMAIN="vpn.example.com"
NH_PROXY_EMAIL="admin@example.com"
NH_BACKEND_LISTEN="127.0.0.1:9445"
NH_TLS_CERT=""
NH_TLS_KEY=""
NH_STACK="both"          # both, naive, or hy2
NH_ACCESS="nginx8080"    # standalone naming; all-in-one exposes panel on 8081 to avoid x-ui 8080 conflicts
NH_PANEL_DOMAIN=""
NH_PANEL_EMAIL=""
NH_SSH_ONLY="0"
NH_MASQUERADE="local"    # local or mirror
NH_MASQUERADE_URL=""

# Optional Cloudflare WARP local proxy.
# Used by: ./install.sh --install-warp --install --yes
WARP_ENABLED="0"
WARP_PROXY_HOST="127.0.0.1"
WARP_PROXY_PORT="40000"
WARP_OUTBOUND_TAG="warp-cli"
WARP_INBOUND_TAG="inbound-443"
WARP_ROUTE_PORT="443"

# Optional bulk profile generator.
GENERATE_PROFILES="0"
PROFILE_COUNT="15"
PROFILE_PREFIX="auto"
